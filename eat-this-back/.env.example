# --- Required ---
OPENAI_API_KEY=sk-your-key-here
# SAM 3 access: https://huggingface.co/facebook/sam3 + https://huggingface.co/settings/tokens
HF_TOKEN=hf_your-token-here

# --- Deployment mode ---
# open   = self-hosted, no auth, everything free (default)
# hosted = segmentation free; recipe/image require Supabase login + credits
APP_MODE=open

# --- Required when APP_MODE=hosted ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional: legacy HS256 JWT secret; leave empty to verify via JWKS
SUPABASE_JWT_SECRET=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Optional tuning ---
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_VISION_DETAIL=low
RECIPE_COST=1
IMAGE_COST=4
ALLOW_DEV_TOPUP=false
DISH_SCOPE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
RECIPE_ENGINE=local
LOG_LEVEL=INFO
